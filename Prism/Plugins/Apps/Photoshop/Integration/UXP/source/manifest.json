{
  "id": "com.prism.photoshop",
  "name": "Prism Pipeline",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": [
    {
      "app": "PS",
      "minVersion": "23.0.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "prismPanel",
      "label": {
        "default": "Prism Pipeline"
      },
      "minimumSize": {
        "width": 300,
        "height": 200
      },
      "maximumSize": {
        "width": 800,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 350,
        "height": 400
      },
      "preferredFloatingSize": {
        "width": 350,
        "height": 400
      },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/prism.png",
          "scale": [
            1,
            2
          ],
          "theme": [
            "dark",
            "darkest",
            "medium",
            "lightest",
            "light"
          ],
          "species": [
            "generic"
          ]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/prism.png",
      "scale": [
        1,
        2
      ],
      "theme": [
        "darkest",
        "dark",
        "medium",
        "lightest",
        "light"
      ]
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://localhost:6400",
        "http://localhost:6401"
      ]
    }
  }
}
